&lt;table border=&#34;1&#34;&gt;
&lt;tr&gt;&lt;th&gt;Passo&lt;/th&gt;&lt;th&gt;i&lt;/th&gt;&lt;th&gt;Saída&lt;/th&gt;&lt;/tr&gt;
&lt;tr&gt;&lt;td&gt;1&lt;/td&gt;&lt;td&gt;1&lt;/td&gt;&lt;td&gt;2&lt;/td&gt;&lt;/tr&gt;
&lt;tr&gt;&lt;td&gt;2&lt;/td&gt;&lt;td&gt;2&lt;/td&gt;&lt;td&gt;4&lt;/td&gt;&lt;/tr&gt;
&lt;tr&gt;&lt;td&gt;3&lt;/td&gt;&lt;td&gt;3&lt;/td&gt;&lt;td&gt;6&lt;/td&gt;&lt;/tr&gt;
&lt;/table&gt;

Saída final: 2 4 6


        &lt;/div&gt;
    &lt;/div&gt;
&lt;/div&gt;

&lt;/div&gt;
&lt;/div&gt;




&lt;div class=&#34;questao-container&#34;&gt;
