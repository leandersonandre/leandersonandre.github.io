      <description>
        
        
        

&lt;div class=&#34;lista-questoes&#34;&gt;


&lt;div class=&#34;questao-container&#34;&gt;
    &lt;div class=&#34;questao-header&#34;&gt;Questão 1&lt;/div&gt;

    &lt;div class=&#34;questao-body&#34;&gt;
Analise o código abaixo e identifique o valor final de x.

&lt;div class=&#34;questao-code&#34;&gt;
    &lt;pre&gt;&lt;code class=&#34;language-&#34;&gt;
x = 1

for i in range(3):
    x = x + i
&lt;/code&gt;&lt;/pre&gt;
    &lt;br /&gt;
&lt;/div&gt;


&lt;li class=&#34;alternativa&#34;&gt;
    &lt;span class=&#34;alternativa-letra&#34;&gt;A.&lt;/span&gt;
     3 
&lt;/li&gt;

&lt;li class=&#34;alternativa&#34;&gt;
    &lt;span class=&#34;alternativa-letra&#34;&gt;B.&lt;/span&gt;
     4 
&lt;/li&gt;
 
&lt;li class=&#34;alternativa&#34;&gt;
    &lt;span class=&#34;alternativa-letra&#34;&gt;C.&lt;/span&gt;
     5 
&lt;/li&gt;

&lt;li class=&#34;alternativa&#34;&gt;
    &lt;span class=&#34;alternativa-letra&#34;&gt;D.&lt;/span&gt;
     6 
&lt;/li&gt;


&lt;div class=&#34;solucao&#34;&gt;
    &lt;div class=&#34;resposta&#34;&gt;
        
        &lt;div class=&#34;resposta-header&#34;&gt;
            &lt;button
                type=&#34;button&#34;
                onclick=&#34;
                    const body = this.parentElement.nextElementSibling;
                    body.classList.toggle(&#39;hidden&#39;);
                    this.textContent = body.classList.contains(&#39;hidden&#39;)
                        ? &#39;Mostrar solução&#39;
                        : &#39;Ocultar solução&#39;;
                &#34;
            &gt;
                Mostrar solução
            &lt;/button&gt;
        &lt;/div&gt;

        
        &lt;div class=&#34;resposta-body hidden&#34;&gt;
            &lt;div class=&#34;resposta-titulo&#34;&gt;
                Resposta correta: &lt;strong&gt;B&lt;/strong&gt;
            &lt;/div&gt;

            

&lt;table border=&#34;1&#34;&gt;
&lt;tr&gt;&lt;th&gt;Passo&lt;/th&gt;&lt;th&gt;Instrução&lt;/th&gt;&lt;th&gt;i&lt;/th&gt;&lt;th&gt;x&lt;/th&gt;&lt;/tr&gt;
&lt;tr&gt;&lt;td&gt;1&lt;/td&gt;&lt;td&gt;x = 1&lt;/td&gt;&lt;td&gt;-&lt;/td&gt;&lt;td&gt;1&lt;/td&gt;&lt;/tr&gt;
&lt;tr&gt;&lt;td&gt;2&lt;/td&gt;&lt;td&gt;i = 0 → x = x + i&lt;/td&gt;&lt;td&gt;0&lt;/td&gt;&lt;td&gt;1&lt;/td&gt;&lt;/tr&gt;
&lt;tr&gt;&lt;td&gt;3&lt;/td&gt;&lt;td&gt;i = 1 → x = x + i&lt;/td&gt;&lt;td&gt;1&lt;/td&gt;&lt;td&gt;2&lt;/td&gt;&lt;/tr&gt;
&lt;tr&gt;&lt;td&gt;4&lt;/td&gt;&lt;td&gt;i = 2 → x = x + i&lt;/td&gt;&lt;td&gt;2&lt;/td&gt;&lt;td&gt;4&lt;/td&gt;&lt;/tr&gt;
&lt;/table&gt;

Resposta: x = 4


        &lt;/div&gt;
    &lt;/div&gt;
&lt;/div&gt;

&lt;/div&gt;
&lt;/div&gt;




&lt;div class=&#34;questao-container&#34;&gt;
    &lt;div class=&#34;questao-header&#34;&gt;Questão 2&lt;/div&gt;

