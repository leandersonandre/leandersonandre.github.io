&lt;div class=&#34;lista-questoes&#34;&gt;


&lt;div class=&#34;questao-container&#34;&gt;
    &lt;div class=&#34;questao-header&#34;&gt;Questão 1&lt;/div&gt;

    &lt;div class=&#34;questao-body&#34;&gt;
Simule o código abaixo e informe o valor final de x.

&lt;div class=&#34;questao-code&#34;&gt;
    &lt;pre&gt;&lt;code class=&#34;language-&#34;&gt;
x = 2

while x &lt; 6:
    x += 2
&lt;/code&gt;&lt;/pre&gt;
    &lt;br /&gt;
&lt;/div&gt;


&lt;div class=&#34;solucao&#34;&gt;
    &lt;div class=&#34;resposta&#34;&gt;
        
        &lt;div class=&#34;resposta-header&#34;&gt;
            &lt;button
                type=&#34;button&#34;
                onclick=&#34;
                    const body = this.parentElement.nextElementSibling;
                    body.classList.toggle(&#39;hidden&#39;);
                    this.textContent = body.classList.contains(&#39;hidden&#39;)
                        ? &#39;Mostrar solução&#39;
                        : &#39;Ocultar solução&#39;;
                &#34;
            &gt;
                Mostrar solução
            &lt;/button&gt;
        &lt;/div&gt;

        
        &lt;div class=&#34;resposta-body hidden&#34;&gt;
            &lt;div class=&#34;resposta-titulo&#34;&gt;
                Resposta correta: &lt;strong&gt; &lt;/strong&gt;
            &lt;/div&gt;

            

&lt;table border=&#34;1&#34;&gt;
  &lt;tr&gt;
    &lt;th&gt;Passo&lt;/th&gt;
    &lt;th&gt;Instrução&lt;/th&gt;
    &lt;th&gt;Condição&lt;/th&gt;
    &lt;th&gt;x&lt;/th&gt;
  &lt;/tr&gt;
  &lt;tr&gt;
    &lt;td&gt;1&lt;/td&gt;
    &lt;td&gt;x = 2&lt;/td&gt;
    &lt;td&gt;-&lt;/td&gt;
    &lt;td&gt;2&lt;/td&gt;
  &lt;/tr&gt;
  &lt;tr&gt;
    &lt;td&gt;2&lt;/td&gt;
    &lt;td&gt;x &amp;lt; 6 → true&lt;/td&gt;
    &lt;td&gt;true&lt;/td&gt;
    &lt;td&gt;2&lt;/td&gt;
  &lt;/tr&gt;
  &lt;tr&gt;
    &lt;td&gt;3&lt;/td&gt;
    &lt;td&gt;x += 2&lt;/td&gt;
    &lt;td&gt;-&lt;/td&gt;
    &lt;td&gt;4&lt;/td&gt;
  &lt;/tr&gt;
  &lt;tr&gt;
    &lt;td&gt;4&lt;/td&gt;
    &lt;td&gt;x &amp;lt; 6 → true&lt;/td&gt;
    &lt;td&gt;true&lt;/td&gt;
    &lt;td&gt;4&lt;/td&gt;
  &lt;/tr&gt;
  &lt;tr&gt;
    &lt;td&gt;5&lt;/td&gt;
    &lt;td&gt;x += 2&lt;/td&gt;
    &lt;td&gt;-&lt;/td&gt;
    &lt;td&gt;6&lt;/td&gt;
  &lt;/tr&gt;
  &lt;tr&gt;
    &lt;td&gt;6&lt;/td&gt;
    &lt;td&gt;x &amp;lt; 6 → false&lt;/td&gt;
    &lt;td&gt;false&lt;/td&gt;
    &lt;td&gt;6&lt;/td&gt;
  &lt;/tr&gt;
&lt;/table&gt;

**Resposta final:** x = 6


        &lt;/div&gt;
    &lt;/div&gt;
&lt;/div&gt;

&lt;/div&gt;
&lt;/div&gt;


