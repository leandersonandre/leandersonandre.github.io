&lt;/li&gt;

&lt;li class=&#34;alternativa&#34;&gt;
    &lt;span class=&#34;alternativa-letra&#34;&gt;D.&lt;/span&gt;
     Impede inserções no meio da lista 
&lt;/li&gt;

&lt;div class=&#34;solucao&#34;&gt;
    &lt;div class=&#34;resposta&#34;&gt;
        
        &lt;div class=&#34;resposta-header&#34;&gt;
            &lt;button
                type=&#34;button&#34;
                onclick=&#34;
