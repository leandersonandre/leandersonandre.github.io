&lt;div id=&#34;plantuml-1777226661042115000&#34;&gt;&lt;/div&gt;

&lt;script&gt;
(async function() {
  const diagram = `\n@startuml\n!theme plain\nskinparam shadowing false\nskinparam monochrome true\nskinparam classAttributeIconSize 0\nhide stereotype\nhide circle\n\nclass Funcionario \u007b\n  -nome: String\n\u007d\n\nclass Departamento \u007b\n  -nome: String\n\u007d\n\nDepartamento \u00221\u0022 o-- \u00220..*\u0022 Funcionario\n\n@enduml\n`;

  const res = await fetch(&#34;https://kroki.io/plantuml/svg&#34;, {
