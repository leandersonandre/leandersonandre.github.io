            &lt;/div&gt;

            
&lt;div id=&#34;plantuml-1777226661042100000&#34;&gt;&lt;/div&gt;

&lt;script&gt;
(async function() {
  const diagram = `\n@startuml\n!theme plain\nskinparam shadowing false\nskinparam monochrome true\nskinparam classAttributeIconSize 0\nhide stereotype\nhide circle\n\nclass Pedido \u007b\n  \u002bfinalizar(): void\n\u007d\n\nclass Pagamento \u007b\n  \u002bprocessar(): void\n\u007d\n\nPedido ..\u003e Pagamento\n\n@enduml\n`;

  const res = await fetch(&#34;https://kroki.io/plantuml/svg&#34;, {
    method: &#34;POST&#34;,
